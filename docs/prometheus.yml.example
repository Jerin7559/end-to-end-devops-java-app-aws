global:
  scrape_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - "localhost:9093"

rule_files:
  - "alerts.yml"

scrape_configs:
  - job_name: "node_exporter"
    static_configs:
      - targets: ["APP_SERVER_PRIVATE_IP:9100"]

  - job_name: "tomcat_jmx"
    static_configs:
      - targets: ["APP_SERVER_PRIVATE_IP:8081"]
